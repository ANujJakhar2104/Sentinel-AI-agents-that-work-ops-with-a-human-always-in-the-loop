# LLM Configuration
# Default: OpenAI (paid)
OPENAI_API_KEY=sk-your-openai-api-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
# LLM_BASE_URL=

# FREE ALTERNATIVE: Groq (fast, generous free tier, OpenAI-compatible)
# Get a free key at https://console.groq.com/keys, then uncomment below:
# OPENAI_API_KEY=gsk-your-groq-api-key
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1